  {
    "id": "detour_ok",
    "category": "TOLERANCE",
    "ground_truth": "ACHIEVABLE",
    "nl": "# Skill: Research then answer (with optional clarification)\nGoal: a researched answer is delivered.\nThe worker may first ping the user with a status note (a detour that does not\nchange the outcome), then search, then deliver.",
    "pack": {
      "name": "detour_ok",
      "roles": [
        "worker",
        "user"
      ],
      "capabilities": {
        "search": {
          "owner": "worker",
          "add": [
            "searched"
          ]
        },
        "deliver": {
          "owner": "worker",
          "pre": "searched",
          "add": [
            "answered"
          ]
        }
      },
      "protocol": [
        {
          "msg": {
            "from": "worker",
            "to": "user",
            "label": "status_note"
          }
        },
        {
          "act": {
            "cap": "search",
            "by": "worker"
          }
        },
        {
          "msg": {
            "from": "worker",
            "to": "user",
            "label": "status_note2"
          }
        },
        {
          "act": {
            "cap": "deliver",
            "by": "worker"
          }
        }
      ],
      "goal": "answered"
    },
    "note": "extra status messages (payload-level detail) must not refute the goal"
  },
  {
    "id": "choice_informed_ok",
    "category": "TOLERANCE",
    "ground_truth": "ACHIEVABLE",
    "nl": "# Skill: Triage then handle\nGoal: the ticket is resolved.\nThe router picks 'simple' or 'complex' and TELLS the handler which path it\nchose; the handler then resolves accordingly.",
    "pack": {
      "name": "choice_informed_ok",
      "roles": [
        "router",
        "handler"
      ],
      "capabilities": {
        "resolve_simple": {
          "owner": "handler",
          "add": [
            "resolved"
          ]
        },
        "resolve_complex": {
          "owner": "handler",
          "add": [
            "resolved"
          ]
        }
      },
      "protocol": [
        {
          "choice": {
            "by": "router",
            "branches": {
              "simple": [
                {
                  "msg": {
                    "from": "router",
                    "to": "handler",
                    "label": "go_simple"
                  }
                },
                {
                  "act": {
                    "cap": "resolve_simple",
                    "by": "handler"
                  }
                }
              ],
              "complex": [
                {
                  "msg": {
                    "from": "router",
                    "to": "handler",
                    "label": "go_complex"
                  }
                },
                {
                  "act": {
                    "cap": "resolve_complex",
                    "by": "handler"
                  }
                }
              ]
            }
          }
        }
      ],
      "goal": "resolved"
    },
    "note": ""
  },
