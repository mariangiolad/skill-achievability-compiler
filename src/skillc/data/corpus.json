  {
    "id": "deadlock_unobserved",
    "category": "DEADLOCK",
    "ground_truth": "IMPOSSIBLE",
    "nl": "# Skill: Plan / worker collaboration\nGoal: the task result is delivered.\nThe worker decides whether to ASK a clarifying question or to DELIVER. In the\n'ask' branch the planner must answer -- but the planner is never told the\nworker chose to ask, so it just keeps waiting for a result. Classic freeze.",
    "pack": {
      "name": "deadlock_unobserved",
      "roles": [
        "planner",
        "worker"
      ],
      "capabilities": {
        "answer": {
          "owner": "planner",
          "add": [
            "answered"
          ]
        },
        "deliver": {
          "owner": "worker",
          "pre": "answered",
          "add": [
            "delivered"
          ]
        },
        "deliver_direct": {
          "owner": "worker",
          "add": [
            "delivered"
          ]
        }
      },
      "protocol": [
        {
          "choice": {
            "by": "worker",
            "branches": {
              "ask": [
                {
                  "act": {
                    "cap": "answer",
                    "by": "planner"
                  }
                },
                {
                  "act": {
                    "cap": "deliver",
                    "by": "worker"
                  }
                }
              ],
              "direct": [
                {
                  "act": {
                    "cap": "deliver_direct",
                    "by": "worker"
                  }
                }
              ]
            }
          }
        }
      ],
      "goal": "delivered"
    },
    "note": "planner must act in 'ask' branch with no distinguishing receive -> NON_PROJECTABLE"
  },
