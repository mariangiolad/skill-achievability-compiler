[
  {
    "id": "retry_loop_ok",
    "category": "TOLERANCE",
    "ground_truth": "ACHIEVABLE",
    "nl": "# Skill: Retry search until found, then deliver\nGoal: answer delivered. Search in a loop; when found, exit and deliver.",
    "pack": {
      "name": "retry_loop_ok",
      "roles": [
        "worker"
      ],
      "capabilities": {
        "search": {
          "owner": "worker",
          "add": [
            "found"
          ]
        },
        "deliver": {
          "owner": "worker",
          "pre": "found",
          "add": [
            "answered"
          ]
        }
      },
      "protocol": [
        {
          "rec": {
            "name": "X",
            "body": [
              {
                "act": {
                  "cap": "search",
                  "by": "worker"
                }
              },
              {
                "choice": {
                  "by": "worker",
                  "branches": {
                    "retry": [
                      {
                        "continue": "X"
                      }
                    ],
                    "found": []
                  }
                }
              }
            ]
          }
        },
        {
          "act": {
            "cap": "deliver",
            "by": "worker"
          }
        }
      ],
      "goal": "answered"
    },
    "note": "tail-recursive retry with an exit branch is inside the fragment"
  },
